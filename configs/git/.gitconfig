[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[fetch]
    prune = true

[core]
    editor = code --wait

[diff]
    tool = vscode

[difftool "vscode"]
    cmd = code --wait --diff $LOCAL $REMOTE

[merge]
    tool = vscode

[mergetool "vscode"]
    cmd = code --wait $MERGED

# 1Password SSH agent
[gpg]
    format = ssh

[gpg "ssh"]
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
    gpgsign = true

# Identity: default to personal
[include]
    path = ~/.gitconfig-personal

# Work identity: prog-leasing-llc repos
[includeIf "gitdir:~/Dev/git/prog-leasing-llc/"]
    path = ~/.gitconfig-work

# Work identity: prog-leasing-llc-legacy repos
[includeIf "gitdir:~/Dev/git/prog-leasing-llc-legacy/"]
    path = ~/.gitconfig-work
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
